# Environment variables template for Magic Resume

FONTCONFIG_PATH=/var/task/fonts

# If set, the site will require this key before access.
# Leave empty to disable the access gate.
# Example: jiangdk
MAGIC_RESUME_ACCESS_KEY=

# Server-side persistence directory (resume + AI config + access key hash).
# Default: data
MAGIC_RESUME_DATA_DIR=data

# Storage backend: sqlite (recommended) or file
MAGIC_RESUME_STORAGE=sqlite

# SQLite database file (relative to MAGIC_RESUME_DATA_DIR unless absolute)
MAGIC_RESUME_SQLITE_PATH=magic-resume.sqlite3
